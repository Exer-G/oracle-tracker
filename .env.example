# Oracle Tracker — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real credentials.

# Option A: standard names (preferred)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Option B: Supabase dashboard export format (also supported)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Netlify Functions
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only, never expose client-side
YOCO_SECRET_KEY=your-yoco-secret-key
FIREFLIES_API_KEY=your-fireflies-api-key
